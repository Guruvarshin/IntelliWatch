# MongoDB Atlas connection string (includes db user, password, and db name)
# Format: mongodb+srv://<user>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority&appName=<cluster-name>
MONGODB_URI=

# Shared secret for signing/verifying session JWTs.
# MUST be identical to AUTH_SECRET in frontend/.env.local
AUTH_SECRET=

# Optional. GitHub personal access token (no scopes needed for public repos).
# Raises the GitHub REST API rate limit from 60/hr (unauthenticated) to
# 5000/hr. Used by github-mcp.
GITHUB_TOKEN=

# OpenAI API key. Used by the Phase 4b extraction node (GPT-4o-mini) and the
# Phase 5 dedup embeddings. Fallback for users who haven't set their own key
# in Settings (Phase 9b BYOK); per-user keys take priority when present.
OPENAI_API_KEY=

# Anthropic API key. Used by the Phase 6 brief writer node (Claude Sonnet).
# Fallback for users who haven't set their own key in Settings (Phase 9b
# BYOK); per-user keys take priority when present.
ANTHROPIC_API_KEY=

# Fernet key for encrypting per-user OpenAI/Anthropic API keys at rest
# (Phase 9b BYOK). Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Shared secret for the GitHub Actions weekly cron job to authenticate to
# /internal/run-all. Sent as the X-Internal-Secret header. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SECRET=

# Brevo (https://brevo.com) API key for sending digest emails.
# Free tier: 300 emails/day, sends to any recipient with no domain verification needed.
BREVO_API_KEY=

# SerpApi key for Google Jobs job postings (https://serpapi.com).
# Used by jobs-mcp as the primary job source for all competitors (no per-competitor
# board config needed). If unset, the jobs source is silently skipped.
# Free plan: 100 searches/month.
SERPAPI_KEY=

# Sender email — must be a verified sender in your Brevo account.
BREVO_FROM_EMAIL=

# Display name shown in the From field (optional, defaults to "IntelliWatch").
BREVO_FROM_NAME=IntelliWatch
